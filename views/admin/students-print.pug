doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Print – Student List
    link(href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    style.
      :root {
        --primary: #1a3c6e;
        --primary-light: #2d6bcf;
        --text: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --bg: #f8fafc;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', sans-serif;
        color: var(--text);
        background: #fff;
        font-size: 13px;
      }

      /* ── Screen toolbar ─────────────────────────── */
      .print-toolbar {
        background: var(--primary);
        padding: 14px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .toolbar-left {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .toolbar-brand {
        font-size: 16px;
        font-weight: 700;
        color: white;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .toolbar-label {
        font-size: 13px;
        color: rgba(255,255,255,0.6);
      }

      .toolbar-actions {
        display: flex;
        gap: 10px;
      }

      .btn-print {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        background: #22c55e;
        color: white;
        border: none;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
      }
      .btn-print:hover { background: #16a34a; }

      .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 20px;
        background: rgba(255,255,255,0.12);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s;
      }
      .btn-back:hover { background: rgba(255,255,255,0.2); }

      /* ── Print document ─────────────────────────── */
      .print-doc {
        max-width: 1100px;
        margin: 32px auto;
        padding: 0 32px 60px;
      }

      /* School letterhead */
      .doc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding-bottom: 20px;
        border-bottom: 3px solid var(--primary);
        margin-bottom: 24px;
      }

      .school-brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .school-logo {
        width: 64px; height: 64px;
        background: var(--primary);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
      }

      .school-info h1 {
        font-size: 22px;
        font-weight: 800;
        color: var(--primary);
        letter-spacing: -0.5px;
      }

      .school-info p {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 2px;
      }

      .doc-meta {
        text-align: right;
      }

      .doc-meta .report-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 4px;
      }

      .doc-meta p {
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.6;
      }

      /* Summary chips */
      .summary-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
      }

      .summary-chip {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
      }

      .chip-total   { background: #eef2ff; color: #4338ca; }
      .chip-pending { background: #fef3c7; color: #92400e; }
      .chip-approved{ background: #dcfce7; color: #065f46; }
      .chip-rejected{ background: #fee2e2; color: #991b1b; }

      .filter-note {
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 16px;
        font-style: italic;
      }

      /* Table */
      .students-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12.5px;
      }

      .students-table thead tr {
        background: var(--primary);
        color: white;
      }

      .students-table th {
        padding: 11px 13px;
        text-align: left;
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
      }

      .students-table td {
        padding: 10px 13px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
      }

      .students-table tbody tr:nth-child(even) {
        background: var(--bg);
      }

      .students-table tbody tr:hover {
        background: #eff6ff;
      }

      .row-num {
        color: var(--text-muted);
        font-weight: 600;
        text-align: center;
        width: 36px;
      }

      .app-num {
        font-family: monospace;
        color: var(--primary-light);
        font-weight: 600;
        white-space: nowrap;
      }

      .student-name { font-weight: 600; }
      .student-sub  { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

      .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
      }

      .badge-pending  { background: #fef3c7; color: #92400e; }
      .badge-approved { background: #dcfce7; color: #065f46; }
      .badge-rejected { background: #fee2e2; color: #991b1b; }

      .empty-row td {
        text-align: center;
        padding: 40px;
        color: var(--text-muted);
        font-style: italic;
      }

      /* Footer */
      .doc-footer {
        margin-top: 32px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
      }

      .doc-footer p {
        font-size: 11px;
        color: var(--text-muted);
        line-height: 1.6;
      }

      .signature-block {
        text-align: right;
      }

      .signature-line {
        width: 180px;
        border-top: 1px solid #94a3b8;
        margin-bottom: 4px;
        margin-left: auto;
      }

      .signature-label {
        font-size: 11px;
        color: var(--text-muted);
      }

      /* ── Print media ────────────────────────────── */
      @media print {
        @page {
          size: A4 landscape;
          margin: 15mm 12mm 15mm 12mm;
        }

        .print-toolbar { display: none !important; }

        body { font-size: 11px; }

        .print-doc {
          margin: 0;
          padding: 0;
          max-width: 100%;
        }

        .students-table thead tr {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          background: var(--primary) !important;
          color: white !important;
        }

        .students-table tbody tr:nth-child(even) {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          background: #f8fafc !important;
        }

        .badge {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }

        .badge-pending  { background: #fef3c7 !important; color: #92400e !important; }
        .badge-approved { background: #dcfce7 !important; color: #065f46 !important; }
        .badge-rejected { background: #fee2e2 !important; color: #991b1b !important; }

        .summary-chip {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }

        .students-table { page-break-inside: auto; }
        .students-table tr { page-break-inside: avoid; page-break-after: auto; }
        .students-table thead { display: table-header-group; }
      }

  body
    //- ── Toolbar (screen only) ────────────────────────────
    .print-toolbar
      .toolbar-left
        .toolbar-brand
          span 🏫
          span Greenfield Academy
        span.toolbar-label Student List – Print Preview
      .toolbar-actions
        a.btn-back(href="/admin/students")
          i.fas.fa-arrow-left
          |  Back
        button.btn-print(onclick="window.print()")
          i.fas.fa-print
          |  Print / Save as PDF

    //- ── Document ──────────────────────────────────────────
    .print-doc
      //- Letterhead
      .doc-header
        .school-brand
          .school-logo 🏫
          .school-info
            h1 Canon Andrea Mwaka International School
            p Official Admissions Office
            p Tel: +255 747 048 991 &nbsp;|&nbsp; info@dodomacams.org
        .doc-meta
          p.report-title Student Admissions Report
          p Generated: #{printDate}
          p Prepared by: #{admin.name}
          if status
            p Filter: #{status.charAt(0).toUpperCase() + status.slice(1)} applications
          if search
            p Search: "#{search}"

      //- Summary chips
      - const counts = { total: students.length, pending: students.filter(s=>s.status==='pending').length, approved: students.filter(s=>s.status==='approved').length, rejected: students.filter(s=>s.status==='rejected').length }
      .summary-bar
        .summary-chip.chip-total
          i.fas.fa-users
          | Total: #{counts.total}
        .summary-chip.chip-pending
          i.fas.fa-hourglass-half
          | Pending: #{counts.pending}
        .summary-chip.chip-approved
          i.fas.fa-check-circle
          | Approved: #{counts.approved}
        .summary-chip.chip-rejected
          i.fas.fa-times-circle
          | Rejected: #{counts.rejected}

      if status || search
        p.filter-note
          | Showing filtered results
          if status
            |  — Status: #{status}
          if search
            |  — Search: "#{search}"

      //- Table
      table.students-table
        thead
          tr
            th.row-num #
            th Application No.
            th Full Name
            th Gender
            th Date of Birth
            th Citizenship
            th Emergency Contact
            th Applied On
            th Status
        tbody
          if students.length
            each s, i in students
              tr
                td.row-num #{i + 1}
                td.app-num #{s.applicationNumber}
                td
                  p.student-name #{s.fullName}
                  if s.motherEmail || s.fatherEmail
                    p.student-sub #{s.motherEmail || s.fatherEmail}
                td #{s.gender}
                td #{s.dateOfBirth}
                td #{s.citizenship}
                td
                  p #{s.emergencyName}
                  p.student-sub #{s.emergencyPhone}
                td #{new Date(s.createdAt).toLocaleDateString('en-GB')}
                td
                  span.badge(class=`badge-${s.status}`) #{s.status}
          else
            tr.empty-row
              td(colspan="9") No students found.

      //- Footer
      .doc-footer
        div
          p Canon Andrea Mwaka International School – Confidential Document
          p This document contains personal information and should be handled accordingly.
          p Total records printed: #{students.length}
        .signature-block
          .signature-line
          p.signature-label Authorised Signature &amp; Stamp
